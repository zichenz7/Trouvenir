{
  "name": "trouvenir-tripo-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "HOST=0.0.0.0 node scripts/tripo-bridge-server.mjs",
    "start": "node scripts/tripo-bridge-server.mjs",
    "web:dev": "vite --config web/vite.config.js --host 127.0.0.1",
    "web:build": "node scripts/ensure-local-public-assets.mjs && vite build --config web/vite.config.js && node scripts/hydrate-dist-assets.mjs",
    "web:hydrate-dist": "node scripts/hydrate-dist-assets.mjs",
    "web:preview": "node scripts/serve-static.mjs dist/web 5173",
    "web:models": "node scripts/generate-placeholder-models.mjs",
    "test:e2e:3d": "node scripts/e2e-3d-render.mjs",
    "build": "tsc",
    "cli": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "verify:ios": "xcodebuild -project ios/Trouvenir.xcodeproj -scheme Trouvenir -destination 'generic/platform=iOS Simulator' build"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "lucide-static": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "esbuild": "^0.25.12",
    "playwright": "^1.60.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^5.4.21"
  }
}
